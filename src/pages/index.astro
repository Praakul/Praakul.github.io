---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);

const skills = [
  "Python",
  "PyTorch",
  "OpenCV",
  "FastAPI",
  "Docker",
  "Linux",
  "C/C++",
  "Git/GitHub",
];
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="flex flex-col items-center gap-4 mb-6 text-center">
      <img
        src="/self_photo_four_is_to_three.jpeg"
        alt="Prajwal Kulkarni"
        class="w-56 h-auto rounded-3xl shadow-lg border-2 border-black/10 dark:border-white/10"
      />
      <div>
        <h4
          class="animate font-semibold text-3xl text-black dark:text-white mb-2"
        >
          Hi, I'm Prajwal Kulkarni
        </h4>
        <p class="animate text-xl text-black/80 dark:text-white/80 font-medium">
          Machine Learning Engineer
        </p>
      </div>
    </div>

    <div class="space-y-8">
      <section class="animate space-y-4">
        <article class="space-y-2 text-center">
          <p>
            hey !! I am a Machine Learning Practioner specializing in Computer Vision and Deep Learning.
            I have previously worked as Research Intern at Department of Neurosurgery, AIIMS, New Delhi and
            Data Science Intern at Tech Fortune Technologies, Bengaluru. I have also been part of Graphics and Vision Summer School 2024 
            conducted at IIT Delhi. My projects are based on Model Calibration, Pose Estimation and Object Detection. 
            I am fascinated by the domain of Vision and xAI. I hold a engineering degree in Electronics and Communications. 
            Actively looking for work opportunities. 
          </p>
        </article>
      </section>

      <section class="animate space-y-4">
        <div class="flex justify-center gap-6 text-lg">
          <Link href="/work"> Experience </Link>
          <Link href="/projects"> Projects </Link>
        </div>
      </section>

      <section class="animate space-y-4 text-center text-base">
        <div class="flex justify-center items-center gap-4 mt-4">
          <Link href="https://github.com/Praakul" external aria-label="GitHub">
            <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
