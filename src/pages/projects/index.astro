---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const existingProjects = projects.filter(p => p.data.projectType === "Projects" || !p.data.projectType);
const sideProjects = projects.filter(p => p.data.projectType === "Side Projects");
const implementations = projects.filter(p => p.data.projectType === "Implementations");
---

<PageLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      {existingProjects.length > 0 && (
        <div class="space-y-4">
          <div class="animate font-semibold text-black dark:text-white">
            Projects
          </div>
          <ul class="animate flex flex-col gap-6">
            {
              existingProjects.map((project) => (
                <li class="h-full">
                  <ArrowCard entry={project}/>
                </li>
              ))
            }
          </ul>
        </div>
      )}
      
      {sideProjects.length > 0 && (
        <div class="space-y-4">
          <div class="animate font-semibold text-black dark:text-white">
            Side Projects
          </div>
          <ul class="animate flex flex-col gap-6">
            {
              sideProjects.map((project) => (
                <li class="h-full">
                  <ArrowCard entry={project}/>
                </li>
              ))
            }
          </ul>
        </div>
      )}

      {implementations.length > 0 && (
        <div class="space-y-4">
          <div class="animate font-semibold text-black dark:text-white">
            Implementations
          </div>
          <ul class="animate flex flex-col gap-6">
            {
              implementations.map((project) => (
                <li class="h-full">
                  <ArrowCard entry={project}/>
                </li>
              ))
            }
          </ul>
        </div>
      )}
    </div>
  </Container>
</PageLayout>
